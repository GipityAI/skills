{
  "description": "Gipity file sync (push on edit, pull on prompt) and terminal-session capture. Every hook no-ops instantly outside Gipity projects (no .gipity.json in the working directory) and never blocks the session. Hooks run through a POSIX-sh launcher (hooks/scripts/launch.sh) that resolves node across version managers (nvm/fnm/asdf/volta), so a version-managed node that isn't on the non-interactive hook PATH no longer breaks sync/capture.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/sync-push.cjs\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture.cjs\" claude-code post-tool-use"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/sync-pull.cjs\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture.cjs\" claude-code session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture.cjs\" claude-code stop"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture.cjs\" claude-code subagent-stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture.cjs\" claude-code session-end"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/capture.cjs\" claude-code pre-compact"
          }
        ]
      }
    ]
  }
}
